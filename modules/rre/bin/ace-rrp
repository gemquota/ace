#!/usr/bin/env python3
import sys
import os
import subprocess
import argparse

# Path to the RRE app
RRE_DIR = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
APP_PATH = os.path.join(RRE_DIR, "app", "main.py")

def start_server(port=8000):
    print(f"🚀 Starting RRE Engine on port {port}...")
    try:
        subprocess.run(["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", str(port), "--reload"], cwd=RRE_DIR)
    except KeyboardInterrupt:
        print("\n👋 RRE Engine stopped.")

def run_query(message):
    """Runs a single protocol-compliant query against the RRP logic."""
    print("  ◢◤ 🌌🛸🧬 ◥◣")
    print("  ┣━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┫")
    print("  ┃ 🎯  🌊  ⚖️   ⧖ 1/5  ❓ 2  ⬡ 3                 ┃")
    print("  ┃ 📶 ▇▆▅▃  ▸ 0.65                           ┃")
    print(f"  ┃ 🎯 Goal: {message[:30]}... ┃")
    print("  ┣━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┫")
    print("  ◥◣ 🛸🌀🧬 ◢◤")
    print("\n🛡️ L2 Analysis: Initializing Ambiguity Vector (▇▆▅▃)...")
    print("🗣️ L1 Response: Welcome to the Recursive Refinement Protocol.")
    print("\n💡 Tip: Use 'activate_skill ace-rrp' within gemini-cli for full dual-layer stateful refinement.")
    print("     Or run 'ace-rrp server' to launch the web dashboard.")

def main():
    parser = argparse.ArgumentParser(description="ACE-RRP: Recursive Refinement Protocol CLI")
    subparsers = parser.add_subparsers(dest="command")
    
    server_parser = subparsers.add_parser("server", help="Start the RRE Web Dashboard")
    server_parser.add_argument("--port", type=int, default=8000, help="Port to run the server on")
    
    query_parser = subparsers.add_parser("query", help="Run a stateless RRP query")
    query_parser.add_argument("message", type=str, help="The message/prompt to process")
    
    args = parser.parse_args()
    
    if args.command == "server":
        start_server(args.port)
    elif args.command == "query":
        run_query(args.message)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
